# Subreddit to monitor
SUBREDDIT_NAME=PhotoshopRequest

# Poll interval in seconds (how often to check for new posts)
POLL_INTERVAL=30

# Firebase Configuration
FIREBASE_PROJECT_ID=

# HMAC Configuration (for API request signing)
HMAC_SECRET=change_this_secret_in_production

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
RATE_LIMIT=60

# CORS Configuration
# For local testing: http://localhost:8000
# For network testing: http://YOUR_IP:8000
ALLOWED_ORIGINS=
