# Subreddit to monitor (plain name or full URL)
# Examples:
#   SUBREDDIT_NAME=PhotoshopRequest
#   SUBREDDIT_NAME=https://www.reddit.com/r/PhotoshopRequest/
SUBREDDIT_NAME=PhotoshopRequest

# Reddit API credentials. Create a Reddit app at:
# https://www.reddit.com/prefs/apps
# For read-only subreddit polling, REDDIT_CLIENT_ID and REDDIT_CLIENT_SECRET are enough.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ReddifLeadMonitor/1.0 by u/YOUR_REDDIT_USERNAME

# Optional. Only set these if your Reddit app/account requires password grant.
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Poll interval in seconds (how often to check for new posts)
POLL_INTERVAL=30

# Adds 0..N seconds of random jitter to each poll sleep to avoid fixed request patterns
POLL_JITTER_SECONDS=5

# Comma-separated Pushshift-compatible base URLs.
# Example: PUSHSHIFT_MIRRORS=https://api.pullpush.io
PUSHSHIFT_MIRRORS=https://api.pullpush.io

# Firebase Configuration
FIREBASE_PROJECT_ID=

# HMAC Configuration (for API request signing)
HMAC_SECRET=change_this_secret_in_production

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
RATE_LIMIT=60

# CORS Configuration
# For local testing: http://localhost:8000
# For network testing: http://YOUR_IP:8000
ALLOWED_ORIGINS=
